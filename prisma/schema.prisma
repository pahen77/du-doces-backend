generator client { provider = "prisma-client-js" }

datasource db { provider = "postgresql"; url = env("DATABASE_URL") }

model Category { id Int @id @default(autoincrement()) name String slug String @unique products Product[] }
model Brand { id Int @id @default(autoincrement()) name String @unique slug String @unique products Product[] }
model Product { id Int @id @default(autoincrement()) name String price Decimal @db.Decimal(10,2) spec String imageUrl String? promo Boolean @default(false) sku String? @unique stock Int @default(100) category   Category  @relation(fields: [categoryId], references: [id]) categoryId Int brand      Brand     @relation(fields: [brandId], references: [id]) brandId Int @@index([categoryId]) @@index([brandId]) @@index([promo]) }
